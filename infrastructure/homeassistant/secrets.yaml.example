# ============================================================
# Home Assistant Secrets — copy to secrets.yaml and fill in
# DO NOT commit secrets.yaml to git (already in .gitignore)
# ============================================================

# ── API Keys — get from each service's Settings → API ────────
sonarr_api_key: YOUR_SONARR_API_KEY        # http://192.168.12.214:8989/settings/general
radarr_api_key: YOUR_RADARR_API_KEY        # http://192.168.12.225:7878/settings/general
prowlarr_api_key: YOUR_PROWLARR_API_KEY    # http://192.168.12.210:9696/settings/general
readarr_api_key: YOUR_READARR_API_KEY      # http://192.168.12.217:8787/settings/general
lidarr_api_key: YOUR_LIDARR_API_KEY        # http://192.168.12.218:8686/settings/general

# ── Jellyfin ─────────────────────────────────────────────────
# Settings → API Keys → + New → copy key
jellyfin_api_key: YOUR_JELLYFIN_API_KEY
# Full header value used in REST commands:
jellyfin_auth_header: "MediaBrowser Token=YOUR_JELLYFIN_API_KEY, Client=HomeAssistant, Device=HA, DeviceId=ha-tiamat, Version=1.0"

# ── Plex ─────────────────────────────────────────────────────
# https://www.plex.tv/claim (expires 4 min — only needed at setup)
plex_token: YOUR_PLEX_TOKEN

# ── Alexa (only if using HA Cloud Alexa skill, not HABridge) ─
# Leave blank if using local HABridge (CT-501) — recommended
alexa_email: ""
alexa_password: ""
