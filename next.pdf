# Exit the container first
exit

# Destroy the empty container
pct stop 950
pct destroy 950 --purge

# Re-run the official Pulse installer (creates a new LXC with Pulse installed)
curl -fsSL https://github.com/rcourtman/Pulse/releases/latest/download/install.sh | bash

# Replace <CTID> with whatever ID the installer chose
pct set <CTID> -net0 name=eth0,bridge=vmbr0,gw=192.168.12.1,ip=192.168.12.251/24,type=veth
pct reboot <CTID>

Then access at http://192.168.12.251:7655

root@pulse:/# curl -fsSL https://raw.githubusercontent.com/rcourtman/Pulse/release/5.1/install.sh | bash
