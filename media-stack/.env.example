# ============================================================
# Media Stack Environment Variables
# Copy to .env and fill in your values
# ============================================================

# User/Group IDs (run: id $USER to get these)
PUID=1000
PGID=1000

# Timezone
TZ=America/Chicago

# Base paths
MEDIA_ROOT=/mnt/media          # Where movies/tv/music are stored
DOWNLOADS_ROOT=/mnt/downloads  # qBittorrent download directory
APPDATA_ROOT=/opt/appdata      # Service config/data directories

# Jellyfin
JELLYFIN_PORT=8096

# Sonarr
SONARR_PORT=8989

# Radarr
RADARR_PORT=7878

# Prowlarr
PROWLARR_PORT=9696

# qBittorrent
QBIT_PORT=9090
QBIT_WEBUI_PORT=9090

# Overseerr
OVERSEERR_PORT=5055

# Bazarr
BAZARR_PORT=6767

# Plex
PLEX_CLAIM=                    # Get from https://plex.tv/claim (expires in 4 min)
PLEX_PORT=32400
TAUTULLI_PORT=8181

# Homarr
HOMARR_PORT=7575

# DuckDNS
DUCKDNS_TOKEN=                 # Get from https://www.duckdns.org
DUCKDNS_DOMAIN=lou-fogle-media-stack

# Traefik
TRAEFIK_DOMAIN=tiamat.local    # Local domain for Traefik routing
ACME_EMAIL=your@email.com      # For Let's Encrypt (if using real domain)
